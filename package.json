    "build:itchio": "bash scripts/build-itchio.sh"
  },
  "dependencies": {
    "@mediapipe/tasks-genai": "^0.10.22",
    "idb": "^8.0.0",
    "pixi.js": "^8.6.6"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "engines": {
    "node": ">=20"
  }
}
